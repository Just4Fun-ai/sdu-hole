# ===== 山大树洞 配置文件 =====
# 复制此文件为 .env 并填写你的配置

SECRET_KEY=please-change-this-to-a-random-string
DATABASE_URL=sqlite+aiosqlite:///./sdu_hole.db
# 线上 PostgreSQL 示例（Railway/Render 等）:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
#
# 前端地址（多个用英文逗号分隔；开发期可用 *）
CORS_ORIGINS=*
ALLOWED_EMAIL_SUFFIX=@mail.sdu.edu.cn
# 管理员学号，多个用英文逗号分隔（例：20250001,20250002）
ADMIN_STUDENT_IDS=

# ===== 邮件模式 =====
# console = 验证码打印在终端（开发测试用）
# smtp    = 真实发送邮件
EMAIL_MODE=smtp

# ===== 方案一：用你自己的山大邮箱发送（推荐） =====
# 用你自己的学号邮箱作为发件人
# 登录 mail.sdu.edu.cn 确认密码可用
SMTP_HOST=smtp.sdu.edu.cn
SMTP_PORT=25
SMTP_USER=你的学号@mail.sdu.edu.cn
SMTP_PASSWORD=你的邮箱密码
SMTP_USE_STARTTLS=false

# ===== 方案二：用163邮箱发送 =====
# 去163邮箱 → 设置 → POP3/SMTP → 开启 → 获取授权码
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_USER=your-email@163.com
# SMTP_PASSWORD=your-authorization-code
# SMTP_USE_STARTTLS=false

# ===== 方案三：用QQ邮箱发送 =====
# 去QQ邮箱 → 设置 → 账户 → 开启SMTP → 获取授权码
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your-qq@qq.com
# SMTP_PASSWORD=your-authorization-code
# SMTP_USE_STARTTLS=false

# ===== 基础防刷（验证码）=====
# 同一邮箱最小发送间隔（秒）
SEND_CODE_MIN_INTERVAL_SECONDS=60
# 同一 IP 在窗口内最多发送次数
SEND_CODE_IP_WINDOW_SECONDS=600
SEND_CODE_MAX_PER_IP_WINDOW=20
# 同一学号在窗口内最多发送次数
SEND_CODE_STUDENT_WINDOW_SECONDS=600
SEND_CODE_MAX_PER_STUDENT_WINDOW=5
# 验证码输错防刷：窗口内错误达到阈值后临时封禁
VERIFY_FAIL_WINDOW_SECONDS=900
VERIFY_MAX_FAIL_PER_EMAIL_WINDOW=8
VERIFY_BLOCK_SECONDS=1800

# ===== 内容安全 =====
# 本地敏感词库文件路径（每行一个词）
SENSITIVE_WORDS_FILE=app/data/sensitive_words.txt
