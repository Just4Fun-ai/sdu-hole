[Unit]
Description=SDU Hole FastAPI Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/sdu-hole/app/sdu-hole
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/sdu-hole/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
